# Backend server configuration.
# Copy this file to .env and fill in real values at runtime.
# Never commit .env.

PORT=3000
PORTAL_BASE_URL=http://localhost:3001
PORTAL_TIMEOUT_MS=5000
SCAN_CACHE_PATH=./data/scanner_cache.json
PORTAL_CACHE_PATH=./cache/portal_cache.json
RATE_LIMIT_SCAN=30
RATE_LIMIT_PORTAL=10
RATE_LIMIT_NEGOTIATE=20

# LLM buyer banter (POST /api/negotiate).
# LLM_PROVIDER picks the brain:
#   anthropic = cloud Claude (needs a PAID ANTHROPIC_API_KEY + internet)   [default]
#   local     = a local OpenAI-compatible server (Ollama, etc.) — FREE + offline
#   auto      = local when no Anthropic key is set, otherwise Anthropic
# With no usable provider it returns the deterministic offline fallback.
LLM_PROVIDER=anthropic

# --- Cloud (Anthropic / Claude) ---
# Leave ANTHROPIC_API_KEY blank to skip cloud. Set ANTHROPIC_MODEL=claude-haiku-4-5
# for faster/cheaper replies (default claude-opus-4-8).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Local (free, no key, no internet) ---
# 1) Install Ollama (https://ollama.com), then in a terminal:  ollama run llama3.2
# 2) Set LLM_PROVIDER=local above. The defaults below match Ollama's OpenAI-style API.
LOCAL_LLM_URL=http://localhost:11434/v1/chat/completions
LOCAL_LLM_MODEL=llama3.2
LOCAL_LLM_API_KEY=ollama

# --- Google Gemini (OpenAI-compatible endpoint) ---
# The backend's local-provider path already sends the key as Bearer and reads
# choices[0].message.content, so no backend code change is needed. To use Gemini:
#   1) Get a free key at https://aistudio.google.com/app/apikey
#   2) Set LLM_PROVIDER=local above.
#   3) Uncomment and fill in the three lines below.
#   4) Verify the current Flash model id in AI Studio (a newer 2.5-flash may exist)
#      and update LOCAL_LLM_MODEL accordingly.
# LOCAL_LLM_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
# LOCAL_LLM_MODEL=gemini-2.0-flash
# LOCAL_LLM_API_KEY=<paste Google AI Studio key here>

# Placeholder key name only. Real key must be injected by environment at runtime.
# PORTAL_API_KEY_NAME=Authorization
