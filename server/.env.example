# Backend server configuration.
# Copy this file to .env and fill in real values at runtime.
# Never commit .env.

PORT=3000
PORTAL_BASE_URL=http://localhost:3001
PORTAL_TIMEOUT_MS=5000
SCAN_CACHE_PATH=./data/scanner_cache.json
PORTAL_CACHE_PATH=./cache/portal_cache.json
RATE_LIMIT_SCAN=30
RATE_LIMIT_PORTAL=10
RATE_LIMIT_NEGOTIATE=20

# LLM buyer banter (POST /api/negotiate). Leave ANTHROPIC_API_KEY blank to use the
# deterministic offline fallback. Set it to enable live, in-character buyer chat.
# Banter is short, single-line text — set ANTHROPIC_MODEL=claude-haiku-4-5 for
# faster/cheaper replies if desired (default is claude-opus-4-8).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Placeholder key name only. Real key must be injected by environment at runtime.
# PORTAL_API_KEY_NAME=Authorization
