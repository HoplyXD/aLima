# Godot 4+ specific ignores
.godot/
/android/

# Godot exports / build output
/build/
/builds/
/export/
/exports/
*.pck
*.zip

# Secrets / environment (never commit real env files; keep .env.example)
.env
*.env
*.env.local
!.env.example

# Python dev tooling (gdtoolkit)
__pycache__/
*.py[cod]
.venv/
venv/

# Node.js backend / mock portal
node_modules/
server/cache/

# Logs and OS cruft
*.log
.DS_Store
Thumbs.db

# On-device AI model files (large; downloaded per machine)
models/*.gguf
